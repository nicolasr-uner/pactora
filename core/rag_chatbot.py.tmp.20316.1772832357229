import os
import streamlit as st
from langchain_community.document_loaders import TextLoader
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_community.vectorstores import Chroma
from langchain_google_genai import GoogleGenerativeAIEmbeddings
from langchain_google_genai import ChatGoogleGenerativeAI
from langchain_core.prompts import ChatPromptTemplate
from typing import List, Dict, Tuple, Optional, Any

class RAGChatbot:
    def __init__(self, persist_directory: str = "./chroma_db", api_key: Optional[str] = None):
        self.persist_directory = persist_directory
        self.api_key = api_key or os.environ.get("GEMINI_API_KEY")
        
        if self.api_key:
            self.embeddings = GoogleGenerativeAIEmbeddings(model="models/embedding-001", google_api_key=self.api_key)
            self.llm = ChatGoogleGenerativeAI(model="gemini-1.5-flash", google_api_key=self.api_key, temperature=0.2)
        else:
            self.embeddings = None
            self.llm = None
        
        self.vectorstore: Any = None
        self._initialize_vectorstore()

    def _initialize_vectorstore(self):
        """Initializes the vectorstore from the persistence directory if it exists."""
        if self.embeddings:
            try:
                if os.path.exists(self.persist_directory):
                    self.vectorstore = Chroma(
                        persist_directory=self.persist_directory,
                        embedding_function=self.embeddings
                    )
            except Exception:
                self.vectorstore = None

    def vector_ingest_multiple(self, documents_list: List[Tuple], metadata_global: Optional[Dict[str, Any]] = None):
        """
        Takes a list of (text_content, filename, metadata) tuples, splits them, and adds to the persistent ChromaDB.
        """
        if not self.embeddings:
            return False, "GEMINI_API_KEY no configurada."
            
        try:
            all_splits = []
            text_splitter = RecursiveCharacterTextSplitter(chunk_size=1500, chunk_overlap=300)
            
            for doc_data in documents_list:
                if len(doc_data) == 3:
                    text_content, filename, meta = doc_data
                else:
                    text_content, filename = doc_data
                    meta = {}

                # Robust metadata handling
                clean_meta = {}
                if isinstance(meta, dict):
                    clean_meta = meta.copy()
                
                if metadata_global:
                    clean_meta.update(metadata_global)
                
                clean_meta["source"] = filename
                
                splits = text_splitter.create_documents([text_content], metadatas=[clean_meta])
                all_splits.extend(splits)
            
            if not all_splits:
                return False, "No se extrajo texto válido."

            if self.vectorstore is None:
                self.vectorstore = Chroma.from_documents(
                    documents=all_splits, 
                    embedding=self.embeddings,
                    persist_directory=self.persist_directory
                )
            else:
                self.vectorstore.add_documents(all_splits)
            
            return True, f"Se han indexado {len(documents_list)} documentos."
            
        except Exception as e:
            return False, str(e)

    def vector_ingest(self, text_content: str, filename: str = "doc", metadata: Optional[Dict[str, Any]] = None):
        return self.vector_ingest_multiple([(text_content, filename, metadata or {})])

    def ask_question(self, question: str, filter_metadata: Optional[Dict[str, Any]] = None) -> str:
        """
        Queries the vector database. Allows metadata filtering.
        """
        if not self.llm:
            return "Gemini LLM no inicializado (revisa tu API Key)."
            
        context_text = ""
        if self.vectorstore is not None:
            try:
                search_kwargs: Dict[str, Any] = {"k": 5}
                if filter_metadata:
                    search_kwargs["filter"] = filter_metadata
                
                docs = self.vectorstore.similarity_search(question, **search_kwargs)
                context_text = "\n---\n".join([d.page_content for d in docs])
            except Exception:
                pass

        system_prompt = (
            "Eres JuanMa, el Cerebro Sectorial Energético de Unergy.\n\n"
            "INSTRUCCIONES:\n"
            "1. Si hay CONTEXTO abajo, úsalo para responder con precisión.\n"
            "2. Si la información no está en el contexto o no hay contexto, responde con tu conocimiento general de IA de forma profesional.\n"
            "3. Identifica riesgos regulatorios si es relevante.\n\n"
            "CONTEXTO DEL WORKSPACE:\n{context}"
        )
        
        prompt = ChatPromptTemplate.from_messages([
            ("system", system_prompt),
            ("human", "{question}"),
        ])
        
        try:
            formatted_prompt = prompt.format_messages(context=context_text, question=question)
            response = self.llm.invoke(formatted_prompt)
            return response.content
        except Exception as e:
            return f"Error en JuanMa: {e}"
